DATABASE_URL="postgresql://precio_sync:precio_sync_dev@localhost:5432/precio_sync"
PORT=3001
NODE_ENV=development

# Auth del panel
JWT_SECRET=
PANEL_USER=
PANEL_PASSWORD=
PANEL_ORIGIN=http://localhost:5173

# API key para n8n
N8N_API_KEY=

# Credenciales JumpSeller — Panel JumpSeller → Configuración → API
JUMPSELLER_LOGIN=
JUMPSELLER_TOKEN=

# OpenAI — platform.openai.com → API Keys
OPENAI_API_KEY=

# Límites IA (opcional — defaults: 50 llamadas/día, 2s entre llamadas)
IA_MAX_CALLS_PER_DAY=50
IA_DELAY_MS=2000
