generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Proveedor {
  id             String   @id @default(cuid())
  nombre         String
  slug           String   @unique
  config         Json
  activo         Boolean  @default(true)
  tema           String?
  descuento      Float    @default(0)
  driveFolderId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  productos Producto[]
  archivos  ArchivoImportado[]
  reglas    ReglaMarkup[]
  ofertas   Oferta[]
  mapeos    MapeoSku[]
}

model Producto {
  id              String   @id @default(cuid())
  sku             String   @unique
  nombre          String
  marca           String?
  categoria       String?
  unidadesCaja    Int?
  unidadesPallet  Int?
  proveedorId     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  proveedor    Proveedor         @relation(fields: [proveedorId], references: [id])
  costos       PrecioCosto[]
  precioVenta  PrecioVenta?
  cambios      CambioPendiente[]
  ofertas      Oferta[]
}

model PrecioCosto {
  id            String   @id @default(cuid())
  productoId    String
  costo         Float
  costoOriginal Float?
  archivoId     String?
  createdAt     DateTime @default(now())

  producto Producto          @relation(fields: [productoId], references: [id])
  archivo  ArchivoImportado? @relation(fields: [archivoId], references: [id])
}

model PrecioVenta {
  id         String   @id @default(cuid())
  productoId String   @unique
  precio     Float
  markupPct  Float?
  updatedAt  DateTime @updatedAt

  producto Producto @relation(fields: [productoId], references: [id])
}

model CambioPendiente {
  id             String    @id @default(cuid())
  productoId     String
  costoAnterior  Float?
  costoNuevo     Float
  precioActual   Float?
  precioSugerido Float?
  estado         String    @default("pendiente")
  archivoId      String?
  aprobadoAt     DateTime?
  createdAt      DateTime  @default(now())

  producto Producto          @relation(fields: [productoId], references: [id])
  archivo  ArchivoImportado? @relation(fields: [archivoId], references: [id])
}

model ArchivoImportado {
  id                String   @id @default(cuid())
  proveedorId       String
  nombre            String
  tipo              String
  estado            String   @default("procesando")
  driveFileId       String?
  driveModifiedTime String?
  totalProductos    Int?
  matcheados        Int?
  sinMatch          Int?
  errores           String?
  sugerenciaConfig  Json?
  createdAt         DateTime @default(now())

  proveedor Proveedor         @relation(fields: [proveedorId], references: [id])
  costos    PrecioCosto[]
  cambios   CambioPendiente[]
}

model ReglaMarkup {
  id             String   @id @default(cuid())
  nombre         String
  proveedorId    String?
  sku            String?
  marca          String?
  categoria      String?
  nombreContiene String?
  costoMin       Float?
  costoMax       Float?
  markupPct      Float
  prioridad      Int      @default(0)
  activa         Boolean  @default(true)
  createdAt      DateTime @default(now())

  proveedor Proveedor? @relation(fields: [proveedorId], references: [id])
}

// Proveedores sin SKU propio (ENGATEL, SCAI, etc.) usan este mapeo
// para relacionar su nombre de producto con el SKU de JumpSeller.
// El matching inicial se hace vía Claude AI y se persiste para evitar repetirlo.
model NombreMapeo {
  id                  String   @id @default(cuid())
  proveedorSlug       String
  nombreProveedor     String
  sku                 String
  jumpsellerProductId Int?
  createdAt           DateTime @default(now())

  @@unique([proveedorSlug, nombreProveedor])
}

model Oferta {
  id           String    @id @default(cuid())
  nombre       String
  tipo         String    // 'proveedor' | 'marca' | 'categoria' | 'producto'
  proveedorId  String?
  marca        String?
  categoria    String?
  productoId   String?
  descuentoPct Float
  fechaInicio  DateTime?
  fechaFin     DateTime?
  activa       Boolean   @default(true)
  publicada    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  proveedor    Proveedor?         @relation(fields: [proveedorId], references: [id])
  producto     Producto?          @relation(fields: [productoId], references: [id])
  aplicaciones OfertaAplicacion[]
}

model OfertaAplicacion {
  id                  String   @id @default(cuid())
  ofertaId            String
  jumpsellerProductId Int
  precioOriginal      Float
  createdAt           DateTime @default(now())

  oferta Oferta @relation(fields: [ofertaId], references: [id], onDelete: Cascade)

  @@unique([ofertaId, jumpsellerProductId])
}

model Notificacion {
  id        String   @id @default(cuid())
  tipo      String
  titulo    String
  mensaje   String
  leida     Boolean  @default(false)
  datos     Json?
  createdAt DateTime @default(now())
}

model MapeoSku {
  id                  String   @id @default(cuid())
  proveedorId         String
  skuProveedor        String
  skuOriginal         String?
  nombreProducto      String?
  jumpsellerProductId Int?
  estado              String   @default("pendiente")
  similitud           Float?
  ultimaVezVisto      DateTime @default(now())
  creadoEn            DateTime @default(now())

  proveedor Proveedor      @relation(fields: [proveedorId], references: [id])
  links     MapeoSkuLink[]

  @@unique([proveedorId, skuProveedor])
}

model MapeoSkuLink {
  id                  String   @id @default(cuid())
  mapeoSkuId          String
  jumpsellerProductId Int
  jumpsellerNombre    String?
  creadoEn            DateTime @default(now())

  mapeoSku MapeoSku @relation(fields: [mapeoSkuId], references: [id], onDelete: Cascade)

  @@unique([mapeoSkuId, jumpsellerProductId])
}

enum Rol {
  admin
  operador
}

model Usuario {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  usuario   String   @unique
  password  String
  rol       Rol      @default(operador)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
